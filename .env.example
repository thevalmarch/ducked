# ── Ducked Engine — Environment Variables ────────────────────────
# Copy this file to .env and modify as needed.
#
#   cp .env.example .env
#
# All variables are optional. The engine runs with sensible defaults.

# ── Discord Alerts ───────────────────────────────────────────────
# Optional webhook URL for operational alerts (rate limits, errors, etc.)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ── Traefik / TLS ────────────────────────────────────────────────
# Email for Let's Encrypt certificate registration (used in docker-compose.yml)
# ACME_EMAIL=thevalmarch@gmail.com
